{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "17895030421624085590"
    }
  },
  "parameters": {
    "appServiceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing App Service"
      }
    },
    "acrName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing Azure Container Registry"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing Storage Account"
      }
    },
    "storageContainerName": {
      "type": "string",
      "defaultValue": "porter-uploads",
      "metadata": {
        "description": "Name of the existing Storage container for uploads"
      }
    },
    "nextauthSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "NextAuth.js secret — generate with: openssl rand -base64 32. Omit from bicepparam and supply via CI secret."
      }
    },
    "nextauthUrl": {
      "type": "string",
      "metadata": {
        "description": "Public URL of the App Service, e.g. https://<name>.azurewebsites.net"
      }
    },
    "googleClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Google OAuth client ID (leave empty to disable)"
      }
    },
    "googleClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Google OAuth client secret"
      }
    },
    "azureAdClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Microsoft Entra ID client ID (leave empty to disable)"
      }
    },
    "azureAdClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Microsoft Entra ID client secret"
      }
    },
    "azureAdTenantId": {
      "type": "string",
      "defaultValue": "common",
      "metadata": {
        "description": "Microsoft Entra ID tenant ID"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region of the existing App Service, e.g. eastus"
      }
    },
    "containerTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Docker image tag to deploy"
      }
    },
    "seedAdminEmail": {
      "type": "string",
      "metadata": {
        "description": "Email address of the initial admin user, created automatically on first container start via the seed script."
      }
    },
    "dbServerName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing PostgreSQL Flexible Server. When set, the connection URL is constructed automatically from the server hostname. Leave empty to supply a raw databaseUrl instead."
      }
    },
    "dbName": {
      "type": "string",
      "defaultValue": "porter",
      "metadata": {
        "description": "Database name (used when dbServerName is set)."
      }
    },
    "dbAdminUser": {
      "type": "string",
      "defaultValue": "porteradmin",
      "metadata": {
        "description": "PostgreSQL admin username (used when dbServerName is set)."
      }
    },
    "dbAdminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "PostgreSQL admin password (used when dbServerName is set). Special characters must be percent-encoded: # → %23, @ → %40, % → %25, : → %3A, ! → %21"
      }
    },
    "databaseUrl": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Full PostgreSQL connection URL. Only used when dbServerName is empty. Special characters in the password must be percent-encoded, e.g. # → %23."
      }
    }
  },
  "variables": {
    "logAnalyticsName": "[format('{0}-logs', parameters('appServiceName'))]",
    "appInsightsName": "[format('{0}-insights', parameters('appServiceName'))]",
    "vnetName": "[format('{0}-vnet', parameters('appServiceName'))]",
    "acrPullRoleId": "7f951dda-4ed3-4680-a7ca-43fe172d538d",
    "storageBlobDataOwnerRoleId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6"
  },
  "resources": [
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServiceName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/porter:{1}', reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer, parameters('containerTag'))]",
          "acrUseManagedIdentityCreds": true,
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2"
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('appServiceName'), 'appsettings')]",
      "properties": {
        "DATABASE_URL": "[if(or(not(empty(parameters('dbServerName'))), not(empty(parameters('databaseUrl')))), format('@Microsoft.KeyVault(VaultName={0};SecretName=database-url)', 'porter-keys'), '')]",
        "NEXTAUTH_URL": "[parameters('nextauthUrl')]",
        "NEXTAUTH_SECRET": "[if(not(empty(parameters('nextauthSecret'))), format('@Microsoft.KeyVault(VaultName={0};SecretName=nextauth-secret)', 'porter-keys'), '')]",
        "AUTH_TRUST_HOST": "true",
        "GOOGLE_CLIENT_ID": "[parameters('googleClientId')]",
        "GOOGLE_CLIENT_SECRET": "[if(not(empty(parameters('googleClientSecret'))), format('@Microsoft.KeyVault(VaultName={0};SecretName=google-client-secret)', 'porter-keys'), '')]",
        "AZURE_AD_CLIENT_ID": "[parameters('azureAdClientId')]",
        "AZURE_AD_CLIENT_SECRET": "[if(not(empty(parameters('azureAdClientSecret'))), format('@Microsoft.KeyVault(VaultName={0};SecretName=sso-porter)', 'porter-keys'), '')]",
        "AZURE_AD_TENANT_ID": "[parameters('azureAdTenantId')]",
        "AZURE_STORAGE_ACCOUNT_URL": "[format('https://{0}.blob.{1}', parameters('storageAccountName'), environment().suffixes.storage)]",
        "AZURE_STORAGE_CONTAINER": "[parameters('storageContainerName')]",
        "DOCKER_REGISTRY_SERVER_URL": "[format('https://{0}', reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer)]",
        "SEED_ADMIN_EMAIL": "[parameters('seedAdminEmail')]",
        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=appinsights-connection-string)', 'porter-keys')]",
        "KEY_VAULT_URL": "[format('https://{0}{1}/', 'porter-keys', environment().suffixes.keyvaultDns)]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appServiceName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 365
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "RetentionInDays": 365
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "porter-keys",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90
      }
    },
    {
      "condition": "[not(empty(parameters('azureAdClientSecret')))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'sso-porter')]",
      "properties": {
        "value": "[parameters('azureAdClientSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "condition": "[not(empty(parameters('nextauthSecret')))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'nextauth-secret')]",
      "properties": {
        "value": "[parameters('nextauthSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "condition": "[not(empty(parameters('dbAdminPassword')))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'db-admin-password')]",
      "properties": {
        "value": "[parameters('dbAdminPassword')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "condition": "[or(not(empty(parameters('dbServerName'))), not(empty(parameters('databaseUrl'))))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'database-url')]",
      "properties": {
        "value": "[if(not(empty(parameters('dbServerName'))), format('postgresql://{0}:{1}@{2}:5432/{3}?sslmode=require', parameters('dbAdminUser'), parameters('dbAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', if(empty(parameters('dbServerName')), 'placeholder', parameters('dbServerName'))), '2023-12-01-preview').fullyQualifiedDomainName, parameters('dbName')), parameters('databaseUrl'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "condition": "[not(empty(parameters('googleClientSecret')))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'google-client-secret')]",
      "properties": {
        "value": "[parameters('googleClientSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', 'porter-keys', 'appinsights-connection-string')]",
      "properties": {
        "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.0.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "app-subnet",
            "properties": {
              "addressPrefix": "10.0.1.0/24",
              "delegations": [
                {
                  "name": "app-service-delegation",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverFarms"
                  }
                }
              ]
            }
          },
          {
            "name": "postgres-subnet",
            "properties": {
              "addressPrefix": "10.0.2.0/24",
              "delegations": [
                {
                  "name": "postgres-delegation",
                  "properties": {
                    "serviceName": "Microsoft.DBforPostgreSQL/flexibleServers"
                  }
                }
              ]
            }
          },
          {
            "name": "endpoints-subnet",
            "properties": {
              "addressPrefix": "10.0.3.0/24",
              "privateEndpointNetworkPolicies": "Disabled"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[format('privatelink.blob.{0}', environment().suffixes.storage)]",
      "location": "global"
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.postgres.database.azure.com",
      "location": "global"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', format('privatelink.blob.{0}', environment().suffixes.storage), format('{0}-blob-link', variables('vnetName')))]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', format('privatelink.blob.{0}', environment().suffixes.storage))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.postgres.database.azure.com', format('{0}-postgres-link', variables('vnetName')))]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}-pe', parameters('storageAccountName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), 'endpoints-subnet')]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "[format('{0}-blob-connection', parameters('storageAccountName'))]",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
              "groupIds": [
                "blob"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('{0}-pe', parameters('storageAccountName')), 'default')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "blob",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', format('privatelink.blob.{0}', environment().suffixes.storage))]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', format('privatelink.blob.{0}', environment().suffixes.storage))]",
        "[resourceId('Microsoft.Network/privateEndpoints', format('{0}-pe', parameters('storageAccountName')))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/networkConfig",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('appServiceName'), 'virtualNetwork')]",
      "properties": {
        "subnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), 'app-subnet')]",
        "swiftSupported": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appServiceName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), parameters('appServiceName'), variables('acrPullRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('acrPullRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appServiceName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), parameters('appServiceName'), variables('storageBlobDataOwnerRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataOwnerRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appServiceName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', 'porter-keys'), parameters('appServiceName'), variables('keyVaultSecretsUserRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUserRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appServiceName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', 'porter-keys')]"
      ]
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('appServiceName')), '2023-12-01').defaultHostName)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer]"
    },
    "dbHostname": {
      "type": "string",
      "value": "[if(not(empty(parameters('dbServerName'))), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', if(empty(parameters('dbServerName')), 'placeholder', parameters('dbServerName'))), '2023-12-01-preview').fullyQualifiedDomainName, '')]"
    },
    "pushCommands": {
      "type": "string",
      "value": "  az acr login --name ${acrName}\r\n  docker build -t ${acr.properties.loginServer}/porter:${containerTag} .\r\n  docker push ${acr.properties.loginServer}/porter:${containerTag}\r\n"
    }
  }
}