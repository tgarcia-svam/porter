# Non-secret configuration — safe to commit.
# Secrets (NEXTAUTH_SECRET, AZURE_AD_CLIENT_SECRET, etc.) are loaded
# automatically from Azure Key Vault at startup via DefaultAzureCredential.
# Run `az login` once to authenticate for local development.

# ── Key Vault ──────────────────────────────────────────────────────
KEY_VAULT_URL=https://porter-app-keys.vault.azure.net/

# ── Auth ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Microsoft Entra ID ─────────────────────────────────────────────
AZURE_AD_CLIENT_ID=6f2fb008-8f5e-4f18-a8d1-6267514660f6
AZURE_AD_TENANT_ID=common

# ── Azure Storage ──────────────────────────────────────────────────
AZURE_STORAGE_CONTAINER=porter-uploads
AZURE_STORAGE_ACCOUNT_URL=https://svamanalyticsporter.blob.core.windows.net/

# ── Database (local dev — points to localhost) ─────────────────────
DATABASE_URL=postgresql://postgres:admin1234@localhost:5432/porter

# ── Seed ───────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=tgarcia@svam.com
