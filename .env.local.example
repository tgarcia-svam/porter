# ── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # openssl rand -base64 32

# Google OAuth  (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Azure AD  (portal.azure.com → App registrations)
AZURE_AD_CLIENT_ID= 
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common           # or your tenant GUID for single-tenant

# ── Azure Blob Storage ────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=porter-uploads

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:admin1234@localhost:5432/porter
