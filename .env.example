# Copy this file to .env and fill in the values.
# .env is read by the Prisma CLI (prisma db push, prisma generate, etc.)
# Secrets should never go here — use .env.local for those.

# ── Key Vault ──────────────────────────────────────────────────────
KEY_VAULT_URL=https://<your-keyvault>.vault.azure.net/

# ── Auth ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Microsoft Entra ID ─────────────────────────────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=common

# ── Azure Storage ──────────────────────────────────────────────────
AZURE_STORAGE_CONTAINER=porter-uploads
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net/

# ── Azure Service Bus (optional — enables async background processing) ──
# When set, large file uploads are processed asynchronously via a queue.
# Without this, uploads are processed synchronously within the HTTP request.
# Namespace format: <your-namespace>.servicebus.windows.net
AZURE_SERVICE_BUS_NAMESPACE=
AZURE_SERVICE_BUS_QUEUE_NAME=porter-uploads
# Shared secret the Azure Function sends in X-Worker-Secret when calling
# /api/upload/process. Generate with: openssl rand -hex 32
UPLOAD_WORKER_SECRET=

# ── Database (required by Prisma CLI — keep in sync with .env.local) ──
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/porter

# ── Seed ───────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=you@example.com
