# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Environment variables — never commit real env files
.env
.env.local
.env.*.local

# Keep example env files for onboarding
!.env.example
!.env.local.example

# Prisma SQLite database
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Misc
.vercel

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfvars
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfplan

# Bicep — secrets.bicepparam is gitignored; main.bicepparam is safe to commit
bicep/*.secrets.bicepparam
